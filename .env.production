# Usado pelo Vite ao rodar `npm run build`
#
# Vercel: manter VITE_API_URL vazio — os rewrites do vercel.json
# redirecionam /api/* para o serverless (api/rpa.ts) que proxia o Railway.
#
# Build standalone local: crie .env.production.local (gitignored) com:
#   VITE_API_URL=http://localhost:8000
VITE_API_URL=
