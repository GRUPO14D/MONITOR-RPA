{
  "name": "MONITOR-RPA",
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "framework": null,
  "rewrites": [
    { "source": "/health", "destination": "/api/rpa?path=health" },
    { "source": "/api/status", "destination": "/api/rpa?path=status" },
    { "source": "/api/events", "destination": "/api/rpa?path=events" },
    { "source": "/((?!api/).*)", "destination": "/index.html" }
  ]
}
